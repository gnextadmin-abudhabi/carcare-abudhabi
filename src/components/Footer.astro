---
import { Icon } from 'astro-icon/components';
import { business } from '../data/business';
import { serviceTypes } from '../data/serviceTypes';
import { serviceAreas } from '../data/serviceAreas';
import { serviceUrl, areaUrl } from '../lib/urls';
---

<footer class="bg-stone-950 text-white">
  <div class="mx-auto max-w-7xl px-5 py-16 lg:px-8">
    <div class="lg:flex lg:items-start lg:gap-16">
      <!-- Brand column -->
      <div class="lg:w-72 lg:shrink-0">
        <a href="/" class="group flex items-center gap-2.5">
          <div class="flex size-9 items-center justify-center rounded-lg bg-brand-900 transition-colors group-hover:bg-brand-800">
            <svg class="size-5 text-brand-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 17H3a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v5" />
              <circle cx="17" cy="17" r="3" />
              <circle cx="7" cy="17" r="3" />
            </svg>
          </div>
          <div class="flex flex-col">
            <span class="font-display text-xl text-white">Al Sham Palace</span>
            <span class="text-[10px] font-medium uppercase tracking-[0.2em] text-stone-500">
              Auto Car Service
            </span>
          </div>
        </a>
        <p class="mt-4 max-w-md text-sm leading-relaxed text-stone-400">
          {business.tagline}. Serving all Abu Dhabi areas since {business.yearEstablished}.
        </p>
      </div>

      <!-- Link columns -->
      <div class="grid gap-8 pt-10 sm:grid-cols-2 lg:grid-cols-3 lg:pt-0 lg:flex-1">
        <!-- Column 1: Our Services -->
        <div>
          <h3 class="mb-4 text-xs font-semibold uppercase tracking-wider text-stone-500">
            Our Services
          </h3>
          <ul class="space-y-2.5">
            {serviceTypes.map((service) => (
              <li>
                <a
                  href={serviceUrl(service.slug)}
                  class="text-sm text-stone-400 transition-colors hover:text-white"
                >
                  {service.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Column 2: Service Areas -->
        <div>
          <h3 class="mb-4 text-xs font-semibold uppercase tracking-wider text-stone-500">
            Service Areas
          </h3>
          <ul class="space-y-2.5">
            {serviceAreas.slice(0, 10).map((area) => (
              <li>
                <a
                  href={areaUrl(area.slug)}
                  class="text-sm text-stone-400 transition-colors hover:text-white"
                >
                  {area.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Column 3: Contact Info -->
        <div>
          <h3 class="mb-4 text-xs font-semibold uppercase tracking-wider text-stone-500">
            Contact Info
          </h3>
          <ul class="space-y-3">
            <li class="flex items-start gap-2.5">
              <Icon name="lucide:map-pin" class="mt-0.5 size-4 shrink-0 text-stone-500" />
              <span class="text-sm text-stone-400">
                {business.address.street}, {business.address.city}, {business.address.country}
              </span>
            </li>
            <li class="flex items-start gap-2.5">
              <Icon name="lucide:phone" class="mt-0.5 size-4 shrink-0 text-stone-500" />
              <a
                href={business.phoneHref}
                class="text-sm text-stone-400 transition-colors hover:text-white"
              >
                {business.phone}
              </a>
            </li>
            <li class="flex items-start gap-2.5">
              <Icon name="lucide:mail" class="mt-0.5 size-4 shrink-0 text-stone-500" />
              <a
                href={`mailto:${business.email}`}
                class="text-sm text-stone-400 transition-colors hover:text-white"
              >
                {business.email}
              </a>
            </li>
            <li class="flex items-start gap-2.5">
              <Icon name="lucide:clock" class="mt-0.5 size-4 shrink-0 text-stone-500" />
              <div class="text-sm text-stone-400">
                {business.hours.map((schedule) => (
                  <p>{schedule.days}: {schedule.hours}</p>
                ))}
              </div>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-10 flex flex-col items-center justify-between gap-3 border-t border-white/10 pt-6 sm:flex-row">
      <p class="text-xs text-stone-600">
        &copy; {new Date().getFullYear()} {business.name}. All rights reserved.
      </p>
      <div class="flex gap-4 text-xs text-stone-600">
        <span>Since {business.yearEstablished}</span>
        <span>Abu Dhabi, UAE</span>
      </div>
    </div>
  </div>
</footer>
