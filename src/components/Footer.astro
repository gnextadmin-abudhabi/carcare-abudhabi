---
import { Icon } from 'astro-icon/components';
import { business } from '../data/business';
import { serviceTypes } from '../data/serviceTypes';
import { serviceAreas } from '../data/serviceAreas';
import { serviceUrl, areaUrl } from '../lib/urls';
---

<footer class="relative overflow-hidden bg-dark-900 text-stone-300">

  <!-- Top divider -->
  <div class="h-px bg-gradient-to-r from-transparent via-brand-500/40 to-transparent"></div>

  <!-- Subtle glow -->
  <div class="pointer-events-none absolute bottom-0 left-1/2 -translate-x-1/2 size-[600px] rounded-full bg-brand-500/4 blur-[120px]"></div>

  <div class="relative mx-auto max-w-7xl px-5 py-16 lg:px-8">
    <div class="grid gap-8 sm:gap-10 lg:gap-12 lg:grid-cols-4">

      <!-- ── Brand column ── -->
      <div class="lg:col-span-1">
        <a href="/" class="group inline-flex shrink-0" aria-label="Al Sham Palace Auto Car Service — Home">
          <div class="size-20 overflow-hidden rounded-2xl ring-2 ring-white/10 transition-all group-hover:ring-brand-500/50 group-hover:scale-105">
            <img src="/images/logo.webp" alt="Al Sham Palace Auto Car Service — Mohamed Bin Zayed City, Abu Dhabi" class="h-full w-full object-cover" width="80" height="80" loading="lazy" />
          </div>
        </a>

        <p class="mt-5 text-sm leading-relaxed text-stone-500">
          {business.tagline}. Trusted by Abu Dhabi drivers since {business.yearEstablished}.
        </p>

        <!-- Quick contact -->
        <div class="mt-6 space-y-3">
          <a href={business.phoneHref} class="flex items-center gap-2.5 text-sm text-stone-400 hover:text-brand-400 transition-colors">
            <Icon name="lucide:phone" class="size-4 text-brand-500/60" />
            {business.phone}
          </a>
          <a href={`mailto:${business.email}`} class="flex items-center gap-2.5 text-sm text-stone-400 hover:text-brand-400 transition-colors">
            <Icon name="lucide:mail" class="size-4 text-brand-500/60" />
            {business.email}
          </a>
          <div class="flex items-start gap-2.5 text-sm text-stone-500">
            <Icon name="lucide:clock" class="mt-0.5 size-4 text-brand-500/60 shrink-0" />
            <div>
              {business.hours.map((h) => (
                <p>{h.days}: {h.hours}</p>
              ))}
            </div>
          </div>
        </div>

        <!-- Social icons -->
        <div class="mt-6 flex items-center gap-3">
          <a href="https://www.instagram.com/al_sham_palace1/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="flex size-9 items-center justify-center rounded-xl bg-white/6 border border-white/8 text-stone-500 transition-all hover:bg-[#E1306C]/15 hover:border-[#E1306C]/30 hover:text-[#E1306C]">
            <svg viewBox="0 0 24 24" fill="currentColor" class="size-4"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="https://www.tiktok.com/@alsham.palace1" target="_blank" rel="noopener noreferrer" aria-label="TikTok" class="flex size-9 items-center justify-center rounded-xl bg-white/6 border border-white/8 text-stone-500 transition-all hover:bg-white/12 hover:border-white/14 hover:text-white">
            <svg viewBox="0 0 24 24" fill="currentColor" class="size-4"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.76a4.85 4.85 0 01-1.01-.07z"/></svg>
          </a>
        </div>

        <!-- WhatsApp button -->
        <a
          href="https://wa.me/971503448933"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-6 inline-flex items-center gap-2 rounded-xl bg-[#25D366]/15 border border-[#25D366]/25 px-4 py-2.5 text-sm font-semibold text-[#25D366] transition-all hover:bg-[#25D366]/25"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" class="size-4">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
          </svg>
          <span class="en-text">Chat on WhatsApp</span>
          <span class="ar-text" style="font-family:'Cairo',sans-serif">تواصل عبر واتساب</span>
        </a>
      </div>

      <!-- ── Services column ── -->
      <div>
        <h3 class="mb-5 text-xs font-bold uppercase tracking-[0.15em] text-stone-500">
          <span class="en-text">Our Services</span><span class="ar-text" style="font-family:'Cairo',sans-serif">خدماتنا</span>
        </h3>
        <ul class="space-y-2.5">
          {serviceTypes.map((s) => (
            <li>
              <a href={serviceUrl(s.slug)} class="group flex items-center gap-2 text-sm text-stone-500 hover:text-brand-400 transition-colors">
                <Icon name="lucide:chevron-right" class="size-3 text-brand-600 transition-transform group-hover:translate-x-0.5" />
                {s.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- ── Areas column ── -->
      <div>
        <h3 class="mb-5 text-xs font-bold uppercase tracking-[0.15em] text-stone-500">
          <span class="en-text">Service Areas</span><span class="ar-text" style="font-family:'Cairo',sans-serif">مناطق الخدمة</span>
        </h3>
        <ul class="space-y-2.5">
          {serviceAreas.slice(0, 12).map((a) => (
            <li>
              <a href={areaUrl(a.slug)} class="group flex items-center gap-2 text-sm text-stone-500 hover:text-brand-400 transition-colors">
                <Icon name="lucide:chevron-right" class="size-3 text-brand-600 transition-transform group-hover:translate-x-0.5" />
                {a.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- ── Address + map link ── -->
      <div>
        <h3 class="mb-5 text-xs font-bold uppercase tracking-[0.15em] text-stone-500">
          <span class="en-text">Find Us</span><span class="ar-text" style="font-family:'Cairo',sans-serif">موقعنا</span>
        </h3>

        <div class="flex items-start gap-2.5 text-sm text-stone-500">
          <Icon name="lucide:map-pin" class="mt-0.5 size-4 shrink-0 text-brand-500/60" />
          <span>{business.address.street}, {business.address.city}, Abu Dhabi, UAE</span>
        </div>

        <!-- Map embed -->
        <div class="mt-5 overflow-hidden rounded-xl border border-white/8 aspect-video sm:aspect-auto">
          <iframe
            src="https://maps.google.com/maps?q=Al+Sham+Palace+Auto+Car+Service+ME10+Mohamed+Bin+Zayed+City+Abu+Dhabi+UAE&hl=en&z=17&output=embed"
            width="100%"
            height="180"
            style="border:0;display:block;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Al Sham Palace Auto Car Service location — MBZ City, Abu Dhabi"
          ></iframe>
        </div>

        <a
          href="https://maps.app.goo.gl/uDuBRuNgejb3Zjk37"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-3 flex items-center gap-2 rounded-xl border border-white/8 bg-white/4 px-4 py-3 text-sm font-medium text-stone-400 hover:text-white hover:border-white/14 transition-all"
        >
          <Icon name="lucide:navigation" class="size-4 text-brand-500" />
          <span class="en-text">Get Directions</span>
          <span class="ar-text" style="font-family:'Cairo',sans-serif">احصل على الاتجاهات</span>
          <Icon name="lucide:external-link" class="size-3 ml-auto text-stone-600" />
        </a>

        <!-- Quick nav -->
        <div class="mt-8 space-y-2">
          <h3 class="mb-3 text-xs font-bold uppercase tracking-[0.15em] text-stone-500">Quick Links</h3>
          {[
            { href: '/about/', label: 'About Us' },
            { href: '/blog/',  label: 'Car Care Blog' },
            { href: '/contact/', label: 'Contact Us' },
            { href: '/privacy/', label: 'Privacy Policy' },
          ].map(({ href, label }) => (
            <a href={href} class="group flex items-center gap-2 text-sm text-stone-500 hover:text-brand-400 transition-colors">
              <Icon name="lucide:chevron-right" class="size-3 text-brand-600 transition-transform group-hover:translate-x-0.5" />
              {label}
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-14 border-t border-white/6 pt-7">
      <div class="flex flex-col items-center justify-between gap-3 text-xs text-stone-600 sm:flex-row">
        <p>&copy; {new Date().getFullYear()} {business.name}. All rights reserved.</p>
        <div class="flex items-center gap-4">
          <!-- Social links -->
          <a href="https://www.instagram.com/al_sham_palace1/" target="_blank" rel="noopener noreferrer" class="hover:text-brand-400 transition-colors">Instagram</a>
          <a href="https://www.tiktok.com/@alsham.palace1" target="_blank" rel="noopener noreferrer" class="hover:text-brand-400 transition-colors">TikTok</a>
          <a href="/privacy/" class="hover:text-stone-400 transition-colors">Privacy Policy</a>
        </div>
      </div>
      <div class="mt-3 text-center text-xs text-stone-700">
        Powered by <a href="https://www.gxlocate.com" target="_blank" rel="noopener noreferrer" class="hover:text-stone-500 transition-colors">www.gxlocate.com</a>
      </div>
    </div>
  </div>
</footer>
