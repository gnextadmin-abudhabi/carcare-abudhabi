---
import { Icon } from 'astro-icon/components';
import { business } from '../data/business';
import LanguageToggle from './LanguageToggle.astro';

const navLinks = [
  { href: '/services/', en: 'Services',      ar: 'الخدمات' },
  { href: '/areas/',    en: 'Service Areas', ar: 'مناطق الخدمة' },
  { href: '/about/',    en: 'About',         ar: 'من نحن' },
  { href: '/blog/',     en: 'Blog',          ar: 'المدونة' },
  { href: '/contact/',  en: 'Contact',       ar: 'تواصل' },
];
---

<header id="site-header" class="fixed top-0 z-50 w-full">
  <!-- Always-present dark bar so nav is always readable -->
  <div class="absolute inset-0 bg-dark-900/95 backdrop-blur-xl border-b border-white/8 shadow-xl"></div>

  <div class="relative mx-auto flex h-20 max-w-7xl items-center justify-between px-5 lg:px-8">

    <!-- ── Logo only (no business name) ── -->
    <a href="/" class="group shrink-0" aria-label="Al Sham Palace Auto Car Service - Home">
      <div class="relative size-[72px] overflow-hidden rounded-xl ring-2 ring-brand-500/30 transition-all duration-300 group-hover:ring-brand-500/60 group-hover:scale-105 group-hover:shadow-lg group-hover:shadow-brand-500/20">
        <img
          src="/images/logo.webp"
          alt="Al Sham Palace Auto Car Service logo — Mohamed Bin Zayed City, Abu Dhabi"
          class="h-full w-full object-cover"
          width="72" height="72"
          decoding="async"
        />
      </div>
    </a>

    <!-- ── Desktop Navigation ── -->
    <nav class="hidden items-center gap-1 lg:flex" role="navigation" aria-label="Main navigation">
      {navLinks.map(({ href, en, ar }) => (
        <a
          href={href}
          class="group relative px-4 py-2.5 text-[0.875rem] font-semibold text-stone-300 transition-colors duration-200 hover:text-white"
        >
          <!-- Animated underline -->
          <span class="absolute bottom-1 left-1/2 h-0.5 w-0 -translate-x-1/2 rounded-full bg-brand-500 transition-all duration-300 group-hover:w-4/5"></span>
          <span class="en-text">{en}</span>
          <span class="ar-text" style="font-family:'Cairo',sans-serif">{ar}</span>
        </a>
      ))}
    </nav>

    <!-- ── Right actions ── -->
    <div class="flex items-center gap-2.5">

      <!-- Language Toggle -->
      <LanguageToggle />

      <!-- WhatsApp -->
      <a
        href="https://wa.me/971503448933"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden items-center gap-2 rounded-full border border-[#25D366]/30 bg-[#25D366]/12 px-4 py-2 text-sm font-semibold text-[#25D366] transition-all duration-200 hover:bg-[#25D366]/22 hover:border-[#25D366]/50 hover:scale-105 sm:inline-flex"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" class="size-4 shrink-0">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
        </svg>
        <span class="en-text">WhatsApp</span>
        <span class="ar-text" style="font-family:'Cairo',sans-serif">واتساب</span>
      </a>

      <!-- Call CTA -->
      <a
        href={business.phoneHref}
        class="btn-shine inline-flex items-center gap-2 rounded-xl bg-brand-500 px-4 py-2.5 text-sm font-bold text-dark-900 shadow-lg shadow-brand-500/25 transition-all duration-200 hover:bg-brand-400 hover:scale-105 hover:shadow-brand-500/40"
      >
        <Icon name="lucide:phone" class="size-4 shrink-0" />
        <span class="hidden sm:inline">{business.phone}</span>
        <span class="en-text sm:hidden">Call</span>
        <span class="ar-text sm:hidden" style="font-family:'Cairo',sans-serif">اتصل</span>
      </a>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        type="button"
        aria-label="Open navigation menu"
        aria-expanded="false"
        class="inline-flex size-10 items-center justify-center rounded-xl border border-white/10 text-stone-300 transition-all hover:bg-white/10 hover:text-white lg:hidden"
      >
        <Icon name="lucide:menu" class="size-5" id="menu-icon-open" />
        <Icon name="lucide:x"    class="hidden size-5" id="menu-icon-close" />
      </button>
    </div>
  </div>

  <!-- ── Mobile Drawer ── -->
  <div
    id="mobile-menu"
    class="hidden border-t border-white/8 bg-dark-900/98 backdrop-blur-2xl lg:hidden"
  >
    <nav class="mx-auto max-w-7xl px-5 py-4" aria-label="Mobile navigation">
      <div class="grid grid-cols-2 gap-2">
        {[
          { href: '/services/', en: 'Services',      ar: 'الخدمات',       icon: 'lucide:wrench' },
          { href: '/areas/',    en: 'Service Areas', ar: 'مناطق الخدمة',  icon: 'lucide:map-pin' },
          { href: '/about/',    en: 'About',         ar: 'من نحن',        icon: 'lucide:info' },
          { href: '/blog/',     en: 'Blog',          ar: 'المدونة',       icon: 'lucide:book-open' },
          { href: '/contact/',  en: 'Contact',       ar: 'تواصل',         icon: 'lucide:mail' },
        ].map(({ href, en, ar, icon }) => (
          <a href={href} class="flex items-center gap-3 rounded-xl border border-white/6 bg-white/4 px-4 py-3.5 text-sm font-semibold text-stone-200 transition-all hover:bg-white/10 hover:text-white hover:border-brand-500/30">
            <Icon name={icon} class="size-4 shrink-0 text-brand-500" />
            <span class="en-text">{en}</span>
            <span class="ar-text" style="font-family:'Cairo',sans-serif">{ar}</span>
          </a>
        ))}
      </div>

      <div class="mt-4 grid grid-cols-2 gap-3">
        <a href={business.phoneHref} class="flex items-center justify-center gap-2 rounded-xl bg-brand-500 px-4 py-3.5 text-sm font-bold text-dark-900 shadow-lg shadow-brand-500/25">
          <Icon name="lucide:phone" class="size-4 shrink-0" />
          {business.phone}
        </a>
        <a href="https://wa.me/971503448933" target="_blank" rel="noopener noreferrer"
           class="flex items-center justify-center gap-2 rounded-xl bg-[#25D366] px-4 py-3.5 text-sm font-bold text-white shadow-lg shadow-[#25D366]/25">
          <svg viewBox="0 0 24 24" fill="currentColor" class="size-4 shrink-0">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
          </svg>
          <span class="en-text">WhatsApp</span>
          <span class="ar-text" style="font-family:'Cairo',sans-serif">واتساب</span>
        </a>
      </div>
    </nav>
  </div>
</header>

<div class="h-20"></div>

<script>
  const btn       = document.getElementById('mobile-menu-btn');
  const menu      = document.getElementById('mobile-menu');
  const iconOpen  = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
  });

  // Add subtle scale shadow on scroll
  const header = document.getElementById('site-header');
  window.addEventListener('scroll', () => {
    header?.style.setProperty('box-shadow', window.scrollY > 10
      ? '0 8px 32px -4px rgba(0,0,0,0.5)'
      : 'none');
  }, { passive: true });
</script>
