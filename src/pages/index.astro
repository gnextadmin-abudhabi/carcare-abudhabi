          <div class="shrink-0 overflow-hidden rounded-2xl border border-white/8 shadow-xl transition-transform duration-300 hover:scale-105">
            <img
              src={`/images/${r}.webp`}
              alt={`5-star Google review — Al Sham Palace Auto Car Service, car repair Abu Dhabi, Mohamed Bin Zayed City (lat 24.3338632, lng 54.5345258)`}
              title="Customer Google Review — Al Sham Palace Auto Car Service Abu Dhabi"
