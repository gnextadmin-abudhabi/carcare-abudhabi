---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
import { business } from '../data/business';
---

<BaseLayout
  title="Page Not Found | Al Sham Palace Auto Car Service Abu Dhabi"
  description="The page you are looking for could not be found. Return to Al Sham Palace Auto Car Service — Abu Dhabi's trusted car service since 1999."
  noindex={true}
>
  <section class="relative flex min-h-[80vh] items-center justify-center overflow-hidden bg-dark-900">
    <!-- Gradient -->
    <div class="pointer-events-none absolute inset-0">
      <div class="absolute left-1/2 top-1/2 size-[600px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-brand-500/8 blur-[120px]"></div>
    </div>

    <div class="relative mx-auto max-w-2xl px-5 py-24 text-center">
      <div class="mx-auto mb-6 flex size-20 items-center justify-center rounded-2xl bg-brand-500/12">
        <Icon name="lucide:map-pin-off" class="size-10 text-brand-400" />
      </div>

      <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-500">404 — Page Not Found</p>

      <h1 class="mt-3 font-display text-4xl text-white sm:text-5xl">
        <span class="en-text">Lost on the Road?</span>
        <span class="ar-text" style="font-family:'Cairo',sans-serif">ضللت الطريق؟</span>
      </h1>

      <p class="mx-auto mt-5 max-w-md text-stone-400">
        <span class="en-text">The page you're looking for doesn't exist. Head back home or contact us directly — we're open daily 9AM to 11:45PM.</span>
        <span class="ar-text" style="font-family:'Cairo',sans-serif">الصفحة التي تبحث عنها غير موجودة. عد إلى الصفحة الرئيسية أو تواصل معنا مباشرة — نحن مفتوحون يومياً من 9 ص حتى 11:45 م.</span>
      </p>

      <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
        <a href="/"
           class="btn-shine inline-flex items-center gap-2 rounded-2xl bg-brand-500 px-7 py-3.5 text-sm font-bold text-dark-900 shadow-xl shadow-brand-500/25 transition-all hover:bg-brand-400 hover:-translate-y-1">
          <Icon name="lucide:home" class="size-4 shrink-0" />
          <span class="en-text">Back to Home</span>
          <span class="ar-text" style="font-family:'Cairo',sans-serif">العودة للرئيسية</span>
        </a>
        <a href={business.phoneHref}
           class="inline-flex items-center gap-2 rounded-2xl border border-white/15 bg-white/6 px-7 py-3.5 text-sm font-semibold text-white transition-all hover:bg-white/12 hover:-translate-y-1">
          <Icon name="lucide:phone" class="size-4 shrink-0" />
          {business.phone}
        </a>
      </div>

      <div class="mt-12 grid grid-cols-2 gap-3 sm:grid-cols-4">
        {[
          { href: '/services/', label: 'Services', labelAr: 'الخدمات', icon: 'lucide:wrench' },
          { href: '/areas/',    label: 'Areas',    labelAr: 'المناطق', icon: 'lucide:map-pin' },
          { href: '/blog/',     label: 'Blog',     labelAr: 'المدونة', icon: 'lucide:book-open' },
          { href: '/contact/',  label: 'Contact',  labelAr: 'تواصل',   icon: 'lucide:mail' },
        ].map(({ href, label, labelAr, icon }) => (
          <a href={href} class="flex items-center justify-center gap-2 rounded-xl border border-white/8 bg-white/4 py-3 text-sm font-medium text-stone-400 transition-all hover:bg-white/10 hover:text-white hover:border-brand-500/30">
            <Icon name={icon} class="size-4 text-brand-500" />
            <span class="en-text">{label}</span>
            <span class="ar-text" style="font-family:'Cairo',sans-serif">{labelAr}</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
